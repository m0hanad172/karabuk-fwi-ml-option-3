%% FireWatch — system architecture
%% Prediction-driven monitoring: scheduled risk checks decide whether
%% the drone patrol cycle runs. CCTV stays always-on regardless.

flowchart LR
    weather["Weather / Historical Data"] --> features["Feature Engineering"]

    sched["Scheduled Risk Checks<br/>09:00 / 11:00 / 15:00<br/>Europe/Istanbul"] --> features
    manual["Manual Risk Check<br/>operator action"] --> features

    features --> prediction["Stage 1 + Stage 2<br/>Wildfire Risk Prediction"]
    prediction --> decision["Risk Decision<br/>Low / Moderate / High"]

    decision -->|"High Risk"| window["Drone Patrol Window<br/>open until next check<br/>(or 17:00 cutoff)"]
    decision -->|"Low / Moderate"| persist1["Store run + state"]

    window --> cycle["30-min Drone Patrol Cycle<br/>launch → inspect → return → standby"]
    cycle --> grid["Priority Grid Cells"]
    grid --> drone_stream["Drone / Video Stream"]
    drone_stream --> detection

    cctv["CCTV / Fixed Cameras<br/>always-on"] --> detection["Fire / Smoke Detection<br/>(YOLOv8)"]
    detection --> alerts["Alert Generation"]

    alerts --> api["FastAPI Backend"]
    persist1 --> api
    decision --> api

    api --> db[("SQLite<br/>run_history<br/>system_state<br/>detection_alerts")]
    api --> dashboard["React Dashboard"]
    db --> dashboard
    dashboard --> operator["Operator"]

    subgraph backend["Backend Runtime"]
        features
        prediction
        decision
        window
        cycle
        detection
        alerts
        api
        db
    end
