# =====================================================================
# Python
# =====================================================================
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
*.egg-info/

# =====================================================================
# Environment / secrets — keep .env.example files tracked
# =====================================================================
.env
.env.*
!.env.example
!**/.env.example

# =====================================================================
# Node / frontend build artefacts
# =====================================================================
node_modules/
dist/
build/
.vite/
.next/
out/

# =====================================================================
# IDE / editor + Claude Code worktrees
# =====================================================================
.idea/
.vscode/
*.code-workspace
.claude/

# =====================================================================
# Logs
# =====================================================================
*.log
logs/

# =====================================================================
# Backend operational state — generated at runtime
# =====================================================================
# Raw / interim data is large or licensed — collaborators rebuild on demand
backend/data/raw/
backend/data/interim/

# Live detection evidence — written every time a fire is detected, so we
# do not want every detection to dirty the working tree. A handful of
# already-tracked samples are kept as demo evidence; new ones are ignored.
backend/data/notifications/*.jsonl
backend/data/notifications/*.jpg
backend/data/notifications/*.jpeg
backend/data/notifications/*.png

# Operational SQLite database (recreated automatically on first boot).
# `backend/outputs/` is the canonical post-restructure path; the
# bare-name globs catch any stray .db / .sqlite files anywhere.
backend/outputs/
*.sqlite
*.sqlite3
*.db

# =====================================================================
# Docker volumes / local overrides
# =====================================================================
docker-compose.override.yml

# =====================================================================
# System files
# =====================================================================
.DS_Store
Thumbs.db
