# Keep the backend image small and reproducible.
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local runtime state — never bake into the image.
outputs/
.env
.env.*
!.env.example

# Tests and dev-only artefacts shouldn't ship in the production image.
tests/

# IDE / editor
.idea/
.vscode/

# Don't bake the venv if one was created locally inside backend/.
.venv/
venv/
