# =====================================================================
# Karabuk FWI ML — backend environment template
# =====================================================================
# Copy this file to `.env` and fill in any values you need to override.
# Every variable below is OPTIONAL — the backend boots successfully with
# zero environment variables set, using the defaults documented here.
# .env is gitignored; .env.example is committed.
# =====================================================================

# Override the SQLite database path used for run history + system state.
# Default: ./outputs/karabuk_fwi.db (auto-created on first boot).
# Used by tests via tests/conftest.py to keep evaluation runs out of the
# operational DB — see SQLITE_GUIDE.md.
# KARABUK_DB_PATH=./outputs/karabuk_fwi.db
