# =====================================================================
# Karabuk FWI ML — backend environment template
# =====================================================================
# Copy this file to `.env` and fill in any values you need to override.
# Every variable below is OPTIONAL - the backend boots successfully
# with zero environment variables set, using the defaults documented
# here. .env is gitignored; .env.example is committed.
# =====================================================================

# Mode selector. Affects:
#   - serve.py: reload=True only when development.
#   - CORS default: localhost frontend allow-list.
#   - DEMO_ALERTS_ENABLED default: dev=true, prod=false.
# Accepted: development | dev | local | production | docker
# Default: development
# BACKEND_ENV=development

# Comma-separated allow-list for the FastAPI CORSMiddleware.
# Default: http://localhost:3000,http://127.0.0.1:3000
# Use "*" only for ad hoc local experiments. Production-like modes
# never default to "*"; set this to the real frontend origin(s).
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Whether the POST /monitoring/alerts/test demo endpoint is available
# AND whether the frontend Detection Alerts tab shows the "Test alert"
# button. Falls back to (BACKEND_ENV != "production") if unset.
# Accepted: 1 / true / yes / on   -> enabled
#           0 / false / no / off  -> disabled
# DEMO_ALERTS_ENABLED=true

# Override the SQLite database path used for run history + system
# state. Default: ./outputs/karabuk_fwi.db relative to backend/.
# Tests use an isolated temp DB via this same variable; see
# backend/tests/conftest.py.
# KARABUK_DB_PATH=./outputs/karabuk_fwi.db

# Fire/smoke detection. The active YOLO detector is
# backend/models/fire_detection/best.pt. Older detector weights are kept
# only as legacy references. This confidence value is shared by webcam,
# PC-camera, and drone video detection.
# MONITORING_YOLO_CONF=0.4
# MONITORING_YOLO_IMGSZ=640
# MONITORING_INFERENCE_STRIDE=3

# Drone-ready adapter. Mock mode is the safe default and requires no
# hardware. Tello mode should be used only for an operator-controlled
# DJI Tello stream demo. Stream start does not mean takeoff.
# DRONE_MODE=mock
# DRONE_AUTO_CONNECT=false
# DRONE_VIDEO_ENABLED=true
# DRONE_ALLOW_MANUAL_CONTROL=false
# DRONE_ALLOW_AUTO_TAKEOFF=false
# DRONE_ALLOW_DEMO_PATROL=false
# DRONE_REQUIRE_OPERATOR_CONFIRMATION=true
# DRONE_BATTERY_MIN_PERCENT=25
# DRONE_COMMAND_TIMEOUT_SECONDS=5
# DRONE_PATROL_SLOT_MINUTES=30
# DRONE_AFTERNOON_CUTOFF_HOUR=17
# DRONE_DEFAULT_STATION_ID=station_1
# DRONE_DEMO_MOVE_CM=100
# DRONE_DEMO_UP_CM=50
# DRONE_DEMO_COMMAND_DELAY_SECONDS=1

# DJI Tello network defaults.
# TELLO_IP=192.168.10.1
# TELLO_COMMAND_PORT=8889
# TELLO_VIDEO_PORT=11111
