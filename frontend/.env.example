# =====================================================================
# Karabuk FWI ML — frontend environment template
# =====================================================================
# Copy this file to `.env.local` (Next.js convention) before running
# `npm run dev` if you need to override the defaults.
# =====================================================================

# Backend API base URL the dashboard fetches from.
# Default (when this variable is unset): http://localhost:8000
# Set this if your backend runs on a different host/port, or if the
# frontend is deployed separately from the API.
NEXT_PUBLIC_API_URL=http://localhost:8000
